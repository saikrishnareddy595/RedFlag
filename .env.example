# Get your free API key at https://build.nvidia.com
NVIDIA_API_KEY=

# Optional: override the model (defaults to meta/llama-3.1-8b-instruct)
# NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# --- Auth (NextAuth.js) ---
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Your site URL (http://localhost:3000 in dev; your Vercel URL in prod)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials from https://console.cloud.google.com
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
